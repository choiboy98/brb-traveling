{
  "name": "brb-traveling",
  "version": "0.1.0",
  "homepage": "https://choiboy98.github.io/brb-traveling",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "static": "next build && touch ./out/.nojekyll && echo 'www.brb-traveling.com' > ./out/CNAME",
    "lint": "next lint",
    "photos:placeholders": "node scripts/generate-placeholder-photos.mjs",
    "shapes:generate": "node scripts/generate-country-shapes.mjs",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d out -t true"
  },
  "dependencies": {
    "next": "^14.0.4",
    "react": "^18",
    "react-dom": "^18",
    "react-lazy-load-image-component": "^1.6.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/react-lazy-load-image-component": "^1.6.3",
    "autoprefixer": "^10.0.1",
    "d3-geo": "^3.1.1",
    "eslint": "^8",
    "eslint-config-next": "14.0.4",
    "gh-pages": "^6.1.1",
    "postcss": "^8",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.3.0",
    "topojson-client": "^3.1.0",
    "topojson-simplify": "^3.0.3",
    "typescript": "^5",
    "world-atlas": "^2.0.2"
  }
}
